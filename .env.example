# Document Intelligence Refinery Environment Configuration

# ──────────────────────────────────────────────────────
# LLM Provider Configuration
# ──────────────────────────────────────────────────────
# Choose your LLM provider: 'gemini', 'openrouter', 'groq', 'ollama', or 'huggingface'
LLM_PROVIDER=openrouter

# Google AI (Gemini) API Key for Query Agent and Vision Strategy
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-1.5-flash

# OpenRouter API Key (alternative LLM provider)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free

# Groq API Key (FAST inference with vision support!)
# Get your free API key at: https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.2-90b-vision-preview

# Ollama (Local LLM - FREE, no API key needed!)
# First install: https://ollama.ai
# Then run: ollama serve
# Then pull model: ollama pull deepseek-coder
# OLLAMA_MODEL=deepseekcoder:latest
# OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace API Token (alternative LLM provider)
# HF_TOKEN=your_huggingface_token_here
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct


# GROK_API_KEY=your_GROK_api_key_here
# ──────────────────────────────────────────────────────
# Other Configuration
# ──────────────────────────────────────────────────────
# Directory for output artifacts (default: .refinery)
REFINERY_OUT_DIR=.refinery
